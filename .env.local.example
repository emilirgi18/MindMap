# Supabase — copy from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Never exposed to the browser. Used only in server actions / route handlers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Auth.uid() value of the admin user.
# Set this to your own user ID after first sign-up to unlock /admin.
ADMIN_USER_ID=your-admin-user-uuid-here

# Public app URL (used for invite link generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000
